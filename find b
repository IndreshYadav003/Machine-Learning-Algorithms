from sklearn.datasets import make_regression
from sklearn.linear_model import LinearRegression
import numpy as np
import matplotlib.pyplot as plt

# Dataset
x,y = make_regression(
    n_samples=4,
    n_features=1,
    n_informative=1,
    noise=80,
    random_state=13
)

# OLS
reg = LinearRegression()
reg.fit(x,y)

m = 78.35
b = 0

lr = 0.1
epochs = 10

for i in range(epochs):

    # Prediction
    y_pred = m*x.ravel() + b

    # Gradient
    gradient = -2*np.sum(y - y_pred)

    # Update b
    b = b - lr*gradient

    # Plot current iteration
    plt.figure(figsize=(6,4))

    plt.scatter(x,y)

    plt.plot(
        x,
        reg.predict(x),
        color='red',
        linewidth=3,
        label='OLS'
    )

    plt.plot(
        x,
        y_pred,
        color='green',
        label=f'Epoch {i+1}'
    )

    plt.title(
        f'Epoch {i+1} | b={round(b,2)}'
    )

    plt.legend()
    plt.show()

print("Final b =",b)
print("OLS b =",reg.intercept_)
